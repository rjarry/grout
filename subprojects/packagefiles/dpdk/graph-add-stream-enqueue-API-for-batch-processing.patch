 lib/graph/graph_private.h              |   2 +
 lib/graph/node.c                       |  40 ++++
 lib/graph/rte_graph.h                  |  25 +++
 lib/graph/rte_graph_worker_common.h    | 261 +++++++++++++++++++++++++
 7 files changed, 356 insertions(+), 38 deletions(-)

