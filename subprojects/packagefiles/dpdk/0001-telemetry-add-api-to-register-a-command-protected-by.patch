From db10b0300fd6f6b4385b1bcc463ef47cdaad8460 Mon Sep 17 00:00:00 2001
From: Robin Jarry <rjarry@redhat.com>
Date: Wed, 25 Sep 2024 16:26:35 -0400
Subject: [PATCH dpdk 1/2] telemetry: add api to register a command protected
 by a lock

Signed-off-by: Robin Jarry <rjarry@redhat.com>
---
 lib/telemetry/rte_telemetry.h | 24 ++++++++++++++++++++++++
 lib/telemetry/telemetry.c     | 33 ++++++++++++++++++++++++++++-----
 lib/telemetry/version.map     |  1 +
 3 files changed, 53 insertions(+), 5 deletions(-)

diff --git a/lib/telemetry/rte_telemetry.h b/lib/telemetry/rte_telemetry.h
index cab9daa6fed6..7b1a54f27f45 100644
--- a/lib/telemetry/rte_telemetry.h
+++ b/lib/telemetry/rte_telemetry.h
@@ -12,6 +12,7 @@ extern "C" {
 #include <stdint.h>
 #include <rte_compat.h>
 #include <rte_common.h>
+#include <rte_spinlock.h>
 
 /** Maximum length for string used in object. */
 #define RTE_TEL_MAX_STRING_LEN 128
@@ -367,6 +368,29 @@ typedef void * (*handler)(void *sock_id);
 int
 rte_telemetry_register_cmd(const char *cmd, telemetry_cb fn, const char *help);
 
+/**
+ * Used when registering a command and callback function with telemetry.
+ *
+ * @param cmd
+ * The command to register with telemetry.
+ * @param fn
+ * Callback function to be called when the command is requested.
+ * @param help
+ * Help text for the command.
+ * @param lock
+ * A lock that will be held while invoking the callback.
+ *
+ * @return
+ *  0 on success.
+ * @return
+ *  -EINVAL for invalid parameters failure.
+ *  @return
+ *  -ENOMEM for mem allocation failure.
+ */
+int
+rte_telemetry_register_cmd_lock(const char *cmd, telemetry_cb fn,
+				const char *help, rte_spinlock_t *lock);
+
 
 /**
  * Get a pointer to a container with memory allocated. The container is to be
diff --git a/lib/telemetry/telemetry.c b/lib/telemetry/telemetry.c
index c4c5a61a5cf8..674fc1ea19f3 100644
--- a/lib/telemetry/telemetry.c
+++ b/lib/telemetry/telemetry.c
@@ -38,6 +38,7 @@ struct cmd_callback {
 	char cmd[MAX_CMD_LEN];
 	telemetry_cb fn;
 	char help[RTE_TEL_MAX_STRING_LEN];
+	rte_spinlock_t *lock;
 };
 
 #ifndef RTE_EXEC_ENV_WINDOWS
@@ -68,8 +69,9 @@ static rte_spinlock_t callback_sl = RTE_SPINLOCK_INITIALIZER;
 static RTE_ATOMIC(uint16_t) v2_clients;
 #endif /* !RTE_EXEC_ENV_WINDOWS */
 
-int
-rte_telemetry_register_cmd(const char *cmd, telemetry_cb fn, const char *help)
+static int
+__rte_telemetry_register_cmd(const char *cmd, telemetry_cb fn,
+			     const char *help, rte_spinlock_t *lock)
 {
 	struct cmd_callback *new_callbacks;
 	const char *cmdp = cmd;
@@ -103,12 +105,26 @@ rte_telemetry_register_cmd(const char *cmd, telemetry_cb fn, const char *help)
 	strlcpy(callbacks[i].cmd, cmd, MAX_CMD_LEN);
 	callbacks[i].fn = fn;
 	strlcpy(callbacks[i].help, help, RTE_TEL_MAX_STRING_LEN);
+	callbacks[i].lock = lock;
 	num_callbacks++;
 	rte_spinlock_unlock(&callback_sl);
 
 	return 0;
 }
 
+int
+rte_telemetry_register_cmd_lock(const char *cmd, telemetry_cb fn,
+				const char *help, rte_spinlock_t *lock)
+{
+	return __rte_telemetry_register_cmd(cmd, fn, help, lock);
+}
+
+int
+rte_telemetry_register_cmd(const char *cmd, telemetry_cb fn, const char *help)
+{
+	return __rte_telemetry_register_cmd(cmd, fn, help, NULL);
+}
+
 #ifndef RTE_EXEC_ENV_WINDOWS
 
 static int
@@ -349,11 +365,16 @@ output_json(const char *cmd, const struct rte_tel_data *d, int s)
 }
 
 static void
-perform_command(telemetry_cb fn, const char *cmd, const char *param, int s)
+perform_command(telemetry_cb fn, rte_spinlock_t *lock, const char *cmd, const char *param, int s)
 {
 	struct rte_tel_data data = {0};
+	int ret;
 
-	int ret = fn(cmd, param, &data);
+	if (lock != NULL)
+		rte_spinlock_lock(lock);
+	ret = fn(cmd, param, &data);
+	if (lock != NULL)
+		rte_spinlock_unlock(lock);
 	if (ret < 0) {
 		char out_buf[MAX_CMD_LEN + 10];
 		int used = snprintf(out_buf, sizeof(out_buf), "{\"%.*s\":null}",
@@ -393,6 +414,7 @@ client_handler(void *sock_id)
 		const char *cmd = strtok(buffer, ",");
 		const char *param = strtok(NULL, "\0");
 		telemetry_cb fn = unknown_command;
+		rte_spinlock_t *lock = NULL;
 		int i;
 
 		if (cmd && strlen(cmd) < MAX_CMD_LEN) {
@@ -400,11 +422,12 @@ client_handler(void *sock_id)
 			for (i = 0; i < num_callbacks; i++)
 				if (strcmp(cmd, callbacks[i].cmd) == 0) {
 					fn = callbacks[i].fn;
+					lock = callbacks[i].lock;
 					break;
 				}
 			rte_spinlock_unlock(&callback_sl);
 		}
-		perform_command(fn, cmd, param, s);
+		perform_command(fn, lock, cmd, param, s);
 
 		bytes = read(s, buffer, sizeof(buffer) - 1);
 	}
diff --git a/lib/telemetry/version.map b/lib/telemetry/version.map
index 2907d28aa03f..3c84708d7ef4 100644
--- a/lib/telemetry/version.map
+++ b/lib/telemetry/version.map
@@ -17,6 +17,7 @@ DPDK_25 {
 	rte_tel_data_start_dict;
 	rte_tel_data_string;
 	rte_telemetry_register_cmd;
+	rte_telemetry_register_cmd_lock;
 
 	local: *;
 };
-- 
2.46.2

